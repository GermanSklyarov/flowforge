{
  "name": "flowforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "tsc -p apps/web/tsconfig.json && node scripts/copy-web-assets.ts",
    "dev": "node scripts/dev.ts",
    "dev:api": "node apps/api/src/index.ts",
    "dev:web": "npm run build:web && node scripts/static-server.ts dist/web 5173",
    "test": "node --test apps/api/test/*.test.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
